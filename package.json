{
  "name": "documentary-factory",
  "version": "0.1.0",
  "description": "Documentary Factory desktop application foundation.",
  "main": "dist-electron/main.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "tsx watch server/index.ts",
    "dev:electron": "wait-on tcp:5173 tcp:3001 && tsc -p electron/tsconfig.json && node scripts/start-electron-dev.mjs",
    "build": "npm run build:web && npm run build:electron && npm run build:server",
    "build:web": "tsc -b tsconfig.json && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:server": "tsc -p tsconfig.server.json",
    "package": "npm run build && electron-builder",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "start:api": "node dist-server/index.js"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@prisma/client": "^6.11.1",
    "@vitejs/plugin-react": "^4.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.16.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "prisma": "^6.11.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.documentaryfactory.app",
    "productName": "Documentary Factory",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "dist-server/**/*",
      "package.json"
    ],
    "extraResources": [
      "prisma/**/*"
    ]
  }
}
